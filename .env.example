# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Auth.js ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-app.railway.app

# --- WhatsApp Cloud API ---
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_ACCESS_TOKEN=your-permanent-access-token
WA_VERIFY_TOKEN=your-custom-webhook-verify-token
WA_APP_SECRET=your-app-secret-for-signature-validation

# --- Anthropic (Claude bot) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=chatbot-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# --- Resend (optional magic-link) ---
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# --- CORS for /api/leads/intake ---
ALLOWED_ORIGINS=https://your-landing.com

# --- App ---
NODE_ENV=production
